# Backend environment variables
# Copy this file to .env and fill in values

# Prisma / SQLite — path is relative to the prisma/ directory
DATABASE_URL="file:../src/database/app.db"

# JWT secrets — generate strong random values for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=replace_me_with_a_long_random_hex_string
REFRESH_TOKEN_SECRET=replace_me_with_another_long_random_hex_string

# Server port
PORT=4001
