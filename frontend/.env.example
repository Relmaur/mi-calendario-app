# Frontend environment variables (Vite)
# All vars must be prefixed with VITE_ to be available in client code.
# Copy this file to .env and fill in values.

# GraphQL backend endpoint
VITE_GRAPHQL_URL=http://localhost:4001/graphql

# Full URL of the login page.
# Currently served by a separate auth app (see docs/architecture.md).
# Change to /login once a login view is added to this Vue app.
VITE_LOGIN_URL=http://localhost:4321/login
